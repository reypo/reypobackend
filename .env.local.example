# Supabase — Dashboard > Project Settings > API sayfasından alınır.
# NEXT_PUBLIC_SUPABASE_URL bir URL olmalı: https://<proje-ref>.supabase.co
# (Yanlışlıkla "publishable key" yapıştırmayın.)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SADECE sunucu tarafı; RLS'i atlar. Asla NEXT_PUBLIC_ ile paylaşmayın.
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (VAPID) — üretmek için: npx web-push generate-vapid-keys
# Bu üçlü hem yerelde hem Vercel'de AYNI olmalı (public key client'a gömülür).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tenekenett@gmail.com
